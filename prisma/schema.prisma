generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js models ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  companyName   String?
  notificationEmail String?
  emailRemindersEnabled Boolean @default(true)
  reminderSchedule String @default("30,14,7,3,1,expired")
  expiredReminderFrequency String @default("once")
  healthyReportFrequency String @default("weekly")
  welcomeEmailSentAt DateTime?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  memberships   OrganizationMember[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── SaaS domain models ───────────────────────────────────────────────────────

model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  isTestData Boolean             @default(false)
  members   OrganizationMember[]
  companies Company[]
  documents Document[]
  importLogs ImportLog[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  role           MemberRole   @default(MEMBER)
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
}

model Company {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents      Document[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Document {
  id             String       @id @default(cuid())
  employeeName   String?
  documentType   String
  referenceId    String
  description    String?      @db.Text
  expiresAt      DateTime
  companyId      String
  organizationId String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([companyId, documentType, referenceId])
  @@index([organizationId])
  @@index([organizationId, employeeName])
  @@index([expiresAt])
  @@index([companyId])
}

model ImportLog {
  id             String       @id @default(cuid())
  organizationId String
  fileName       String?
  imported       Int          @default(0)
  created        Int          @default(0)
  updated        Int          @default(0)
  skipped        Int          @default(0)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}

model NotificationLog {
  id             String   @id @default(cuid())
  organizationId String
  documentId     String
  userId         String
  userEmail      String
  alertType      String
  reminderKey    String?
  status         String   @default("SENT")
  error          String?  @db.Text
  sentAt         DateTime @default(now())

  @@index([organizationId])
  @@index([documentId, userId, alertType])
  @@index([documentId, userId, reminderKey])
}

model AlertRead {
  id             String   @id @default(cuid())
  organizationId String
  documentId     String
  userId         String
  alertKey       String
  readAt         DateTime @default(now())

  @@unique([documentId, userId, alertKey])
  @@index([organizationId, userId])
}

enum UserRole {
  USER
  ADMIN
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

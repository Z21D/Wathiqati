# Database (Neon Postgres)
# Neon Dashboard → Connect → copy connection string
# Use Direct connection for migrations/db push; pooled is fine for runtime on Vercel
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Email provider
# Development can use gmail with a Gmail App Password.
# Production should use resend with a verified sending domain.
EMAIL_PROVIDER="resend"

# Gmail provider (development)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Resend provider (production)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Wathiqati <onboarding@resend.dev>"
RESEND_WEBHOOK_SECRET=""
RESEND_TEST_TO=""

# Optional local reminder scenario recipients.
# Use two real inboxes or plus-address aliases to verify User A/User B isolation.
REMINDER_TEST_USER_A_EMAIL="reminder-user-a@example.com"
REMINDER_TEST_USER_A_NOTIFY_EMAIL=""
REMINDER_TEST_USER_B_EMAIL="reminder-user-b@example.com"
REMINDER_TEST_USER_B_NOTIFY_EMAIL=""

# Vercel Cron protection
CRON_SECRET=""

# OAuth (Google Sign-In)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URIs (add both for local + production):
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_PRODUCTION_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Database (Neon Postgres)
# Neon Dashboard → Connect → copy connection string
# Use Direct connection for migrations/db push; pooled is fine for runtime on Vercel
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Email reminders (optional for local dev)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="ExpiryGuard <onboarding@resend.dev>"
RESEND_TEST_TO=""

# Optional local reminder scenario recipients.
# Use two real inboxes or plus-address aliases to verify User A/User B isolation.
REMINDER_TEST_USER_A_EMAIL="reminder-user-a@example.com"
REMINDER_TEST_USER_A_NOTIFY_EMAIL=""
REMINDER_TEST_USER_B_EMAIL="reminder-user-b@example.com"
REMINDER_TEST_USER_B_NOTIFY_EMAIL=""

# Vercel Cron protection
CRON_SECRET=""

# OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
